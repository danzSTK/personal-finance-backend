# Danfy Backend — ambiente local
#
# Este arquivo contém a união das variáveis usadas pela API e pelo worker.
# Copie-o para `.env` na raiz do repositório. Não comite o arquivo resultante.
#
# Convenções:
# - OBRIGATÓRIA: não possui default e o processo não inicia sem um valor válido.
# - CONDICIONAL: passa a ser obrigatória quando a condição indicada é atendida.
# - DEFAULT: pode ser omitida; o valor informado é aplicado pelo schema Joi.
# - OPCIONAL: pode ser omitida e não possui default no schema Joi.
#
# A matriz completa está em docs/configuration.md.

# ==============================================================================
# ORQUESTRAÇÃO E PAPEL DO PROCESSO
# ==============================================================================

# OBRIGATÓRIA pelo Docker Compose — tag local ou versão da imagem.
APP_VERSION=local

# DEFAULT: api — os scripts e o serviço Compose do worker sobrescrevem para worker.
PROCESS_ROLE=api

# ==============================================================================
# COMPARTILHADAS — API E WORKER
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL — OBRIGATÓRIAS
# ------------------------------------------------------------------------------

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_local_db_user
POSTGRES_PASSWORD=your_local_db_password
POSTGRES_DB=danfy_local

# ------------------------------------------------------------------------------
# Redis de cache e sessões — OBRIGATÓRIAS
# ------------------------------------------------------------------------------

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_local_redis_password

# DEFAULT: 3600 segundos.
REDIS_TTL=3600

# ------------------------------------------------------------------------------
# BullMQ Redis e política padrão dos jobs
# ------------------------------------------------------------------------------

# OBRIGATÓRIA.
BULLMQ_REDIS_HOST=localhost

# DEFAULT Joi: 6379. O exemplo usa 6381 porque essa é a porta publicada no host
# pelo docker-compose.dev.yml.
BULLMQ_REDIS_PORT=6381

# OPCIONAL no Joi. O ambiente local usa autenticação no container dedicado.
BULLMQ_REDIS_PASSWORD=your_local_bullmq_redis_password

# DEFAULT Joi: 1. O ambiente local usa explicitamente o DB 0.
BULLMQ_REDIS_DB=0

# DEFAULTS aplicados pela configuração de filas.
BULLMQ_PREFIX=personal-finance
BULLMQ_DEFAULT_ATTEMPTS=5
BULLMQ_BACKOFF_TYPE=exponential
BULLMQ_BACKOFF_DELAY_MS=5000
BULLMQ_REMOVE_ON_COMPLETE=1000
BULLMQ_REMOVE_ON_FAIL=5000

# ------------------------------------------------------------------------------
# Cloudflare R2 — OBRIGATÓRIAS
# ------------------------------------------------------------------------------

# Os valores abaixo são placeholders e não representam credenciais reais.
R2_ENDPOINT=https://example-account-id.r2.cloudflarestorage.com
R2_ACCOUNT_ID=example_cloudflare_account_id
R2_ACCESS_KEY_ID=example_r2_access_key_id
R2_SECRET_ACCESS_KEY=example_r2_secret_access_key
R2_PUBLIC_BUCKET_NAME=danfy-public-example
R2_PRIVATE_BUCKET_NAME=danfy-private-example
R2_PUBLIC_BASE_URL=https://assets.example.com

# ------------------------------------------------------------------------------
# Aplicação e frontend
# ------------------------------------------------------------------------------

# OBRIGATÓRIA — usada em URLs de notificações e redirecionamentos.
FRONTEND_URL=http://localhost:5173

# DEFAULT: development. Valores válidos: development, production ou test.
NODE_ENV=development

# ------------------------------------------------------------------------------
# Verificação de e-mail — compartilhada
# ------------------------------------------------------------------------------

# DEFAULTS usados na criação das intenções de notificação.
NOTIFICATIONS_EMAIL_VERIFICATION_PATH=/verification-email
NOTIFICATIONS_EMAIL_VERIFICATION_PROVIDER_TEMPLATE_ID=3
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=15
EMAIL_VERIFICATION_RESEND_COOLDOWN_MINUTES=60
EMAIL_VERIFICATION_DAILY_LIMIT=5

# CONDICIONAL: obrigatório quando MAIL_ENABLED=true.
# Quando o envio está desabilitado, o default é http://localhost:5173/support.
SUPPORT_URL=http://localhost:5173/support

# ==============================================================================
# SOMENTE API
# ==============================================================================

# ------------------------------------------------------------------------------
# HTTP e URL pública
# ------------------------------------------------------------------------------

# OBRIGATÓRIA para PROCESS_ROLE=api.
APP_URL=http://localhost:3000

# DEFAULT: 3000.
PORT=3000

# ------------------------------------------------------------------------------
# JWT — OBRIGATÓRIAS para PROCESS_ROLE=api
# ------------------------------------------------------------------------------

# Substitua por duas chaves distintas com ao menos 32 caracteres.
# Gere valores locais com: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_a_distinct_local_access_secret_32_chars_minimum
JWT_REFRESH_SECRET=replace_with_a_distinct_local_refresh_secret_32_chars_minimum
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------------------------------------------
# Google OAuth — OBRIGATÓRIAS para PROCESS_ROLE=api
# ------------------------------------------------------------------------------

# Os placeholders permitem o bootstrap, mas não autenticam no Google.
GOOGLE_CLIENT_ID=example_google_client_id
GOOGLE_CLIENT_SECRET=example_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
GOOGLE_LINK_CALLBACK_URI=http://localhost:3000/auth/providers/link/google/callback

# ------------------------------------------------------------------------------
# CORS/CSRF — OBRIGATÓRIA para PROCESS_ROLE=api
# ------------------------------------------------------------------------------

# Lista CSV de origins completas. Inclua APP_URL para usar o Swagger local.
CSRF_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------------------------------------------
# Rate limiting
# ------------------------------------------------------------------------------

# DEFAULTS globais.
THROTTLE_DEFAULT_TTL=60000
THROTTLE_DEFAULT_LIMIT=20

# OPCIONAIS, sem default no Joi. Quando informadas, especializam os fluxos.
THROTTLE_AUTH_SIGNIN_TTL=60000
THROTTLE_AUTH_SIGNIN_LIMIT=5
THROTTLE_AUTH_SIGNIN_BLOCKED_TTL=600000
THROTTLE_AUTH_SIGNUP_TTL=600000
THROTTLE_AUTH_SIGNUP_LIMIT=10
THROTTLE_AUTH_SIGNUP_BLOCKED_TTL=1800000

# ==============================================================================
# SOMENTE WORKER
# ==============================================================================

# ------------------------------------------------------------------------------
# Consumo de filas, outbox e lifecycle
# ------------------------------------------------------------------------------

# DEFAULT: 5.
BULLMQ_DEFAULT_CONCURRENCY=5

# DEFAULTS do dispatcher da transactional outbox.
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=25
OUTBOX_CONCURRENCY=5
OUTBOX_LEASE_MS=30000
OUTBOX_LEASE_RENEW_INTERVAL_MS=10000

# DEFAULTS da reconciliação entre PostgreSQL e BullMQ.
EMAIL_ENQUEUE_RECONCILE_INTERVAL_MS=30000
EMAIL_ENQUEUE_RECONCILE_BATCH_SIZE=100
EMAIL_ENQUEUE_STALE_AFTER_MS=30000

# DEFAULTS de encerramento e heartbeat.
WORKER_SHUTDOWN_TIMEOUT_MS=30000
WORKER_HEARTBEAT_INTERVAL_MS=10000
WORKER_HEARTBEAT_TTL_MS=30000

# OPCIONAL, com fallback para o hostname da réplica.
WORKER_INSTANCE_ID=worker-local-example

# ------------------------------------------------------------------------------
# E-mail transacional
# ------------------------------------------------------------------------------

# DEFAULTS seguros para local: nenhum e-mail externo será enviado.
MAIL_ENABLED=false
MAIL_PROVIDER=noop

# CONDICIONAL: obrigatório no worker quando MAIL_ENABLED=true.
MAIL_DEFAULT_FROM_EMAIL=no-reply@example.com

# OPCIONAL, sem default.
MAIL_DEFAULT_FROM_NAME=Danfy

# CONDICIONAL: obrigatório quando PROCESS_ROLE=worker, MAIL_ENABLED=true e
# MAIL_PROVIDER=brevo. Este valor é somente um placeholder.
BREVO_API_KEY=example_brevo_api_key

# DEFAULTS do cliente Brevo.
BREVO_API_BASE_URL=https://api.brevo.com/v3
BREVO_API_TIMEOUT_MS=10000
BREVO_API_MAX_RETRIES=2

# ------------------------------------------------------------------------------
# Welcome e-mail — DEFAULTS
# ------------------------------------------------------------------------------

NOTIFICATIONS_DASHBOARD_PATH=/dashboard
NOTIFICATIONS_EMAIL_PREFERENCES_PATH=/settings/email-preferences
SUPPORT_URL_LABEL=Central de ajuda

# ==============================================================================
# INVARIANTES DO WORKER
# ==============================================================================
#
# OUTBOX_LEASE_RENEW_INTERVAL_MS deve ser menor que OUTBOX_LEASE_MS.
# OUTBOX_CONCURRENCY não pode ser maior que OUTBOX_BATCH_SIZE.
# WORKER_HEARTBEAT_INTERVAL_MS deve ser menor que WORKER_HEARTBEAT_TTL_MS.
