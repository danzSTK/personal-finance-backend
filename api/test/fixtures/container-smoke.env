# Valores ficticios usados somente pelo smoke test de containers da CI.
API_ENV_FILE=api/test/fixtures/container-smoke.env
WORKER_ENV_FILE=api/test/fixtures/container-smoke.env

NODE_ENV=test
PROCESS_ROLE=api
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
CSRF_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=container_smoke
POSTGRES_PASSWORD=container-smoke-postgres-password
POSTGRES_DB=container_smoke

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=container-smoke-redis-password
REDIS_TTL=60

BULLMQ_REDIS_HOST=bullmq-redis
BULLMQ_REDIS_PORT=6379
BULLMQ_REDIS_PASSWORD=container-smoke-bullmq-password
BULLMQ_REDIS_DB=0
BULLMQ_PREFIX=container-smoke
WORKER_INSTANCE_ID=container-smoke-worker

JWT_ACCESS_SECRET=container-smoke-access-secret-with-at-least-32-characters
JWT_REFRESH_SECRET=container-smoke-refresh-secret-with-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=container-smoke-google-client
GOOGLE_CLIENT_SECRET=container-smoke-google-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
GOOGLE_LINK_CALLBACK_URI=http://localhost:3000/auth/providers/link/google/callback

R2_ENDPOINT=http://localhost:9000
R2_ACCOUNT_ID=container-smoke-account
R2_ACCESS_KEY_ID=container-smoke-access-key
R2_SECRET_ACCESS_KEY=container-smoke-secret-key
R2_PUBLIC_BUCKET_NAME=container-smoke-public
R2_PRIVATE_BUCKET_NAME=container-smoke-private
R2_PUBLIC_BASE_URL=http://localhost:9000/public

MAIL_ENABLED=false
MAIL_PROVIDER=noop
MAIL_DEFAULT_FROM_EMAIL=no-reply@example.com
MAIL_DEFAULT_FROM_NAME=Container Smoke
